# ── Ashen Studio Dashboard — Caddyfile ─────────────────────
# Serves static files and reverse proxies API / pgAdmin
# requests to the backend.
#
# API_UPSTREAM_URL — set via environment variable. This is the
# internal Docker network URL where the FastAPI backend lives.
# Defaults to http://ashenapi-api:8000 (matching the container
# name in the API stack's docker-compose.yml).
# ───────────────────────────────────────────────────────────

{$API_UPSTREAM_URL:http://ashenapi-api:8000}

:80 {
    root * /app
    encode gzip

    # ── Security headers ──────────────────────────────────
    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "SAMEORIGIN"
        X-XSS-Protection "1; mode=block"
        Referrer-Policy "strict-origin-when-cross-origin"
    }

    # ── API proxy ─────────────────────────────────────────
    handle /api/* {
        header {
            -X-Frame-Options
        }

        reverse_proxy {$API_UPSTREAM_URL} {
            header_up X-Forwarded-Host {host}
            header_up X-Forwarded-Proto {scheme}
            header_up X-Forwarded-Prefix /api
        }
    }

    # ── pgAdmin proxy ─────────────────────────────────────
    handle /pgadmin/* {
        header {
            -X-Frame-Options
        }

        reverse_proxy {$API_UPSTREAM_URL} {
            header_up X-Forwarded-Host {host}
            header_up X-Forwarded-Proto {scheme}
            header_up X-Forwarded-Prefix /pgadmin
        }
    }

    # ── Static files (everything else) ────────────────────
    handle {
        file_server
    }
}
